#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // 物理配置(2行3列):
            //  1  2  3
            //  4  5  6
            bindings = <
                &kp N1  &kp N2  &kp N3
                &kp N4  &kp N5  &kp N6
            >;
        };
    };
};
